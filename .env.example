# ──────────────────────────────────────────────────────────────────────────
# Custos environment variables. Copy to `.env` and fill in.
# NEVER commit `.env`. All values below are placeholders.
# ──────────────────────────────────────────────────────────────────────────

# ── Chain / RPC ───────────────────────────────────────────────────────────
# Mantle mainnet (chainId 5000). RPC list (updated regularly):
# https://github.com/1delta-DAO/rpc-tester/raw/refs/heads/main/rpcs/5000.json
MANTLE_RPC_URL=https://rpc.mantle.xyz
MANTLE_TESTNET_RPC_URL=https://rpc.sepolia.mantle.xyz
# How long to wait (ms) for a submitted tx's receipt before the cycle fails loud
# (bounded waiting only; no fee-bump/replacement). Default 120000.
TX_RECEIPT_TIMEOUT_MS=
# O4 crash-recovery tx journal: path to a small JSON file recording the last
# submitted tx. The executor writes it before awaiting the receipt and clears it
# on confirmation, so a crash mid-flight is reconciled at startup (and a still-
# unconfirmed REQUIRED de-risk pages the operator). Leave blank to disable.
# In Docker this is mounted on a volume (see docker-compose.yml) so it survives
# restarts, e.g. /data/state.json.
AGENT_STATE_PATH=

# ── LLM (Anthropic API / Claude) ──────────────────────────────────────────
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# ── Data (1delta) ─────────────────────────────────────────────────────────
# API key from auth.1delta.io. Data + swap routing/quoting ONLY (aggregates
# Odos/Eisen/Nordstern). The route calldata it returns is executed only against
# the pinned USDY_AGGREGATOR_ROUTER below, with an oracle-derived on-chain minOut.
ONEDELTA_API_KEY=
ONEDELTA_BASE_URL=https://api.1delta.io

# Pinned DEX aggregator router the UsdyAdapter executes calldata against (Odos on
# Mantle). Immutable at deploy; MUST be verified on-chain (Phase-0 gate). USDY
# liquidity on Mantle is split across thin pools, so a single-pool route is unusable.
USDY_AGGREGATOR_ROUTER=

# ── Signers (NEVER commit real keys) ──────────────────────────────────────
# Deployer: deploys contracts. Allocator: guardrail-bounded hot key.
DEPLOYER_PRIVATE_KEY=
ALLOCATOR_PRIVATE_KEY=

# ── Governance (mainnet deploy) ───────────────────────────────────────────
# Final admin (a Safe multisig). REQUIRED on mainnet and must differ from the
# deployer: Deploy.s.sol grants DEFAULT_ADMIN_ROLE + ADMIN to it on every
# admin-bearing contract, then the deployer renounces its own roles (H4).
ADMIN_ADDRESS=
# Optional guarded-launch bootstrap for the guardrail timelock (seconds).
# Minimum 3600 (the on-chain MIN_TIMELOCK floor). Recommended for v1: 21600 (6h)
# during the mainnet shakeout, then queueConfig the value back up to 172800 (48h)
# once smoke tests pass. Unset/0 keeps the 2-day default. See docs/deploy.md.
INITIAL_TIMELOCK_SECONDS=

# ── IPFS pinning (rationale + evidence) ───────────────────────────────────
IPFS_API_URL=          # Kubo-compatible HTTP API, e.g. http://localhost:5001; omit to use data: URI fallback
IPFS_PINNING_JWT=
IPFS_GATEWAY_URL=https://gateway.pinata.cloud

# ── Frontend ──────────────────────────────────────────────────────────────
# The web app reads LIVE on-chain by default, auto-resolving the deployed vault
# from @custos/shared for the active chain (no VITE_VAULT_ADDRESS needed). It
# defaults to whichever chain has a committed deployment (testnet today). Set
# VITE_DEMO_MODE=true to force the typed fixtures (for screenshots / the demo video).
VITE_DEMO_MODE=                  # "true" forces fixture/demo data; blank/false = live on-chain reads
VITE_WALLETCONNECT_PROJECT_ID=   # WalletConnect Cloud project id; omit for local injected-only dev
VITE_DEFAULT_CHAIN=              # force "mantle" (5000) or "testnet" (5003); blank = auto (the deployed chain)
VITE_MANTLE_RPC_URL=             # optional RPC override (defaults to https://rpc.mantle.xyz)
VITE_MANTLE_TESTNET_RPC_URL=     # optional RPC override (defaults to https://rpc.sepolia.mantle.xyz)
VITE_VAULT_ADDRESS=              # optional override; blank = use the committed @custos/shared address for the chain
VITE_AGENT_ID=                   # ERC-8004 agent token id, set after RegisterIdentity.s.sol
VITE_VAULT_DEPLOY_BLOCK=         # Block number of vault deploy tx; scopes getLogs to avoid full-chain scan
VITE_AGENT_API_URL=             # Agent base URL for live risk radar (/snapshot) + /ask; blank = fixture

# ── Deployed contract addresses (resolved at deploy time) ─────────────────
# Optional for read-only/dev runs; required for the agent execution path.
# Populated from deployments/<chainId>.json after Deploy.s.sol broadcast.
VAULT_ADDRESS=
GUARDRAILS_ADDRESS=
BENCHMARK_ADDRESS=
AAVE_ADAPTER_ADDRESS=
USDY_ADAPTER_ADDRESS=
AUSD_ADAPTER_ADDRESS=
AGENT_ID=

# ── Testnet mock token addresses (only if Mantle Sepolia lacks real tokens) ─
# Set these after running: forge script script/DeployMocks.s.sol --rpc-url $MANTLE_TESTNET_RPC_URL --broadcast
TESTNET_USDC=
TESTNET_USDY=
TESTNET_MUSD=                    # Ondo mUSD wrap/unwrap converter; leave blank to deploy a USDY-only adapter
TESTNET_USDY_ORACLE=
TESTNET_USDY_ROUTER=
TESTNET_AUSD=                    # AUSD token (safety bucket); AusdAdapter skipped if blank
TESTNET_AAVE_POOL=
TESTNET_AUSDC=
ALLOCATOR_ADDRESS=
GUARDIAN_ADDRESS=

# ── Alerts (A3.2) — optional; fire on de-risk events ─────────────────────
TELEGRAM_BOT_TOKEN=      # BotFather token; set with TELEGRAM_CHAT_ID to enable Telegram alerts
TELEGRAM_CHAT_ID=        # numeric chat/channel id (e.g. -100xxxxxxxx for channels)
DISCORD_WEBHOOK_URL=     # Discord channel webhook URL; set to enable Discord alerts

# ── x402 micropayments (A4.1) — optional; sell the RWA risk score per-call ──
# Set X402_PAY_TO to enable GET /risk-score as a 402-gated endpoint. Payment is an
# EIP-3009 transferWithAuthorization on X402_ASSET (an EIP-3009/USDC-style token).
X402_PAY_TO=             # recipient address for x402 payments (enables the paid endpoint)
X402_ASSET=              # EIP-3009 token used to pay (e.g. USDC 0x09Bc4E0D...0dF9)
X402_PRICE_BASE_UNITS=10000   # price in token base units (10000 = 0.01 USDC, 6-dec)
X402_NETWORK=mantle      # human network label carried in requirements/receipts
X402_TOKEN_NAME=USD Coin # EIP-712 domain name of X402_ASSET
X402_TOKEN_VERSION=2     # EIP-712 domain version of X402_ASSET
X402_TIMEOUT_SECONDS=120 # how long a signed payment authorization stays valid
X402_PREMIUM_FEED_URL=   # optional x402-gated feed the agent PAYS for; receipt pinned into decisions
X402_MAX_PRICE_BASE_UNITS=  # REQUIRED when X402_PREMIUM_FEED_URL is set: reject feed prices above this (base units) before signing
X402_SETTLE_ONCHAIN=false # true: settle /risk-score payments on-chain (needs ALLOCATOR wallet); false: verify signature, facilitator settles

# ── Agent service ─────────────────────────────────────────────────────────
AGENT_PORT=8080
AGENT_LOG_LEVEL=info

# ── Explorer verification (mantlescan) ────────────────────────────────────
MANTLESCAN_API_KEY=
