# ──────────────────────────────────────────────────────────────────────────
# Sentinel environment variables. Copy to `.env` and fill in.
# NEVER commit `.env`. All values below are placeholders.
# ──────────────────────────────────────────────────────────────────────────

# ── Chain / RPC ───────────────────────────────────────────────────────────
# Mantle mainnet (chainId 5000). RPC list (updated regularly):
# https://github.com/1delta-DAO/rpc-tester/raw/refs/heads/main/rpcs/5000.json
MANTLE_RPC_URL=https://rpc.mantle.xyz
MANTLE_TESTNET_RPC_URL=https://rpc.sepolia.mantle.xyz
# Pinned fork block for deterministic tests (set during Phase 0).
FORK_BLOCK_NUMBER=

# ── LLM (Anthropic API / Claude) ──────────────────────────────────────────
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# ── Data (1delta) ─────────────────────────────────────────────────────────
# API key from auth.1delta.io. Data + optional swap routing ONLY.
ONEDELTA_API_KEY=
ONEDELTA_BASE_URL=https://api.1delta.io

# ── Signers (NEVER commit real keys) ──────────────────────────────────────
# Deployer: deploys contracts. Allocator: guardrail-bounded hot key.
DEPLOYER_PRIVATE_KEY=
ALLOCATOR_PRIVATE_KEY=

# ── IPFS pinning (rationale + evidence) ───────────────────────────────────
IPFS_API_URL=          # Kubo-compatible HTTP API, e.g. http://localhost:5001; omit to use data: URI fallback
IPFS_PINNING_JWT=
IPFS_GATEWAY_URL=https://gateway.pinata.cloud

# ── Frontend ──────────────────────────────────────────────────────────────
VITE_WALLETCONNECT_PROJECT_ID=   # WalletConnect Cloud project id; omit for local injected-only dev
VITE_DEFAULT_CHAIN=mantle        # "mantle" (5000) or "testnet" (5003)
VITE_MANTLE_RPC_URL=             # optional RPC override (defaults to https://rpc.mantle.xyz)
VITE_MANTLE_TESTNET_RPC_URL=     # optional RPC override (defaults to https://rpc.sepolia.mantle.xyz)
VITE_VAULT_ADDRESS=              # Sentinel vault; enables live dashboard reads once deployed (task 4.4)

# ── Deployed contract addresses (resolved at deploy time) ─────────────────
# Optional for read-only/dev runs; required for the agent execution path.
VAULT_ADDRESS=
GUARDRAILS_ADDRESS=
BENCHMARK_ADDRESS=

# ── Agent service ─────────────────────────────────────────────────────────
AGENT_PORT=8080
AGENT_LOG_LEVEL=info

# ── Explorer verification (mantlescan) ────────────────────────────────────
MANTLESCAN_API_KEY=
