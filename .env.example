# ──────────────────────────────────────────────────────────────────────────
# Custos environment variables. Copy to `.env` and fill in.
# NEVER commit `.env`. All values below are placeholders.
#
# IMPORTANT: keep comments on their OWN lines. Do NOT put inline `# comments`
# after a value — Docker Compose `env_file` does not strip them and would treat
# the comment text as part of the value (breaking URL/hex/number fields).
# ──────────────────────────────────────────────────────────────────────────

# ── Chain / RPC ───────────────────────────────────────────────────────────
# Mantle mainnet (chainId 5000). RPC list (updated regularly):
# https://github.com/1delta-DAO/rpc-tester/raw/refs/heads/main/rpcs/5000.json
MANTLE_RPC_URL=https://rpc.mantle.xyz
MANTLE_TESTNET_RPC_URL=https://rpc.sepolia.mantle.xyz
# How long to wait (ms) for a submitted tx's receipt before the cycle fails loud
# (bounded waiting only; no fee-bump/replacement). Default 120000.
TX_RECEIPT_TIMEOUT_MS=
# O4 crash-recovery tx journal: path to a small JSON file recording the last
# submitted tx. The executor writes it before awaiting the receipt and clears it
# on confirmation, so a crash mid-flight is reconciled at startup (and a still-
# unconfirmed REQUIRED de-risk pages the operator). Leave blank to disable.
# In Docker this is mounted on a volume (see docker-compose.yml) so it survives
# restarts, e.g. /data/state.json.
AGENT_STATE_PATH=

# ── LLM (Anthropic API / Claude) ──────────────────────────────────────────
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
# Optional: override the Anthropic-compatible API base URL to point the SDK at a
# different gateway (e.g. a GLM/other Anthropic-compatible endpoint). Blank = default.
ANTHROPIC_BASE_URL=

# ── Data (1delta) ─────────────────────────────────────────────────────────
# API key from auth.1delta.io. Data + swap routing/quoting ONLY (aggregates
# Odos/Eisen/Nordstern). The route calldata it returns is executed only against
# the pinned USDY_AGGREGATOR_ROUTER below, with an oracle-derived on-chain minOut.
ONEDELTA_API_KEY=
ONEDELTA_BASE_URL=https://portal.1delta.io

# Pinned 1delta swap executor the UsdyAdapter/AusdAdapter run calldata against.
# 1delta's /actions/swap routes every swap through this single contract; the adapter
# pre-approves it and executes its returned calldata under an oracle-derived
# balance-delta minOut. Immutable at deploy; MUST equal the adapters' on-chain
# AGGREGATOR. extcodesize = 1581 on Mantle mainnet.
USDY_AGGREGATOR_ROUTER=0x5C019a146758287C614FE654CaEC1ba1CaF05F4E

# ── Signers (NEVER commit real keys) ──────────────────────────────────────
# Deployer: deploys contracts. Allocator: guardrail-bounded hot key.
DEPLOYER_PRIVATE_KEY=
ALLOCATOR_PRIVATE_KEY=

# ── Governance (mainnet deploy) ───────────────────────────────────────────
# Final admin (a Safe multisig). REQUIRED on mainnet and must differ from the
# deployer: Deploy.s.sol grants DEFAULT_ADMIN_ROLE + ADMIN to it on every
# admin-bearing contract, then the deployer renounces its own roles (H4).
ADMIN_ADDRESS=
# Optional: adopt an already-deployed, still-un-bootstrapped Guardrails instead of
# deploying a fresh one (resume a deploy that failed after Guardrails was created but
# before its setConfig landed). The deployer must still hold its admin roles. Leave
# blank to deploy a new Guardrails.
EXISTING_GUARDRAILS=
# Optional guarded-launch bootstrap for the guardrail timelock (seconds).
# Minimum 3600 (the on-chain MIN_TIMELOCK floor). Recommended for v1: 21600 (6h)
# during the mainnet shakeout, then queueConfig the value back up to 172800 (48h)
# once smoke tests pass. Unset/0 keeps the 2-day default. See docs/deploy.md.
INITIAL_TIMELOCK_SECONDS=

# ── IPFS pinning (rationale + evidence) ───────────────────────────────────
# Pinata:       IPFS_API_URL=https://api.pinata.cloud + IPFS_PINNING_JWT=<jwt>
# Self-hosted:  IPFS_API_URL=http://localhost:5001 (Kubo; JWT optional)
# Omit IPFS_API_URL entirely to use the data: URI fallback (local/fork demo).
IPFS_API_URL=
# Bearer token for the pinning API; required by Pinata.
IPFS_PINNING_JWT=
# Read-only gateway that resolves ipfs:// for the UI (your xxx.mypinata.cloud works
# too). MUST include the https:// scheme or config validation rejects it.
IPFS_GATEWAY_URL=https://gateway.pinata.cloud

# ── Frontend ──────────────────────────────────────────────────────────────
# The web app reads LIVE on-chain by default, auto-resolving the deployed vault
# from @custos/shared for the active chain (no VITE_VAULT_ADDRESS needed). It
# defaults to whichever chain has a committed deployment (testnet today). Set
# VITE_DEMO_MODE=true to force the typed fixtures (for screenshots / the demo video).
# NOTE: the web build reads web/.env.production, not this file — these VITE_* keys
# are listed here for reference.
# "true" forces fixture/demo data; blank/false = live on-chain reads.
VITE_DEMO_MODE=
# WalletConnect Cloud project id; omit for local injected-only dev.
VITE_WALLETCONNECT_PROJECT_ID=
# Force "mantle" (5000) or "testnet" (5003); blank = auto (the deployed chain).
VITE_DEFAULT_CHAIN=
# Optional RPC override (defaults to https://rpc.mantle.xyz).
VITE_MANTLE_RPC_URL=
# Optional RPC override (defaults to https://rpc.sepolia.mantle.xyz).
VITE_MANTLE_TESTNET_RPC_URL=
# Optional override; blank = use the committed @custos/shared address for the chain.
VITE_VAULT_ADDRESS=
# ERC-8004 agent token id, set after RegisterIdentity.s.sol.
VITE_AGENT_ID=
# Block number of vault deploy tx; scopes getLogs to avoid a full-chain scan.
VITE_VAULT_DEPLOY_BLOCK=
# Agent base URL for live risk radar (/snapshot) + /ask; blank = fixture.
VITE_AGENT_API_URL=

# ── Deployed contract addresses (resolved at deploy time) ─────────────────
# Optional for read-only/dev runs; required for the agent execution path.
# Populated from deployments/<chainId>.json after Deploy.s.sol broadcast.
VAULT_ADDRESS=
GUARDRAILS_ADDRESS=
BENCHMARK_ADDRESS=
AAVE_ADAPTER_ADDRESS=
USDY_ADAPTER_ADDRESS=
AUSD_ADAPTER_ADDRESS=
# ERC-8004 agent token id (printed by RegisterIdentity.s.sol; a positive integer —
# registry ids start at 1). The agent also uses it to bind the x402 payee to identity:
# with X402_PAY_TO unset, /risk-score revenue goes to ownerOf(AGENT_ID); with it set, a
# mismatch vs the owner logs a warning.
AGENT_ID=

# ── Testnet mock token addresses (only if Mantle Sepolia lacks real tokens) ─
# Set these after running: forge script script/DeployMocks.s.sol --rpc-url $MANTLE_TESTNET_RPC_URL --broadcast
TESTNET_USDC=
TESTNET_USDY=
# Ondo mUSD wrap/unwrap converter; leave blank to deploy a USDY-only adapter.
TESTNET_MUSD=
TESTNET_USDY_ORACLE=
TESTNET_USDY_ROUTER=
# AUSD token (safety bucket); AusdAdapter skipped if blank.
TESTNET_AUSD=
TESTNET_AAVE_POOL=
TESTNET_AUSDC=
# Allocator address WITHOUT the key — also read by keyless agent runs (card:pin
# wallet + the never-pay-the-allocator x402 guard).
ALLOCATOR_ADDRESS=
GUARDIAN_ADDRESS=

# ── Alerts (A3.2) — optional; fire on de-risk events ─────────────────────
# BotFather token; set with TELEGRAM_CHAT_ID to enable Telegram alerts.
TELEGRAM_BOT_TOKEN=
# Numeric chat/channel id (e.g. -100xxxxxxxx for channels).
TELEGRAM_CHAT_ID=
# Discord channel webhook URL; set to enable Discord alerts.
DISCORD_WEBHOOK_URL=

# ── x402 micropayments (A4.1) — optional; sell the RWA risk score per-call ──
# X402_ASSET is the opt-in: when set (plus a payee — X402_PAY_TO or AGENT_ID),
# GET /risk-score becomes a 402-gated endpoint. Payment is an EIP-3009
# transferWithAuthorization on X402_ASSET (an EIP-3009/USDC-style token).
# The payee is published in the pinned ERC-8004 agent card (`sells.payTo`, see
# `pnpm card:pin`) so payers can verify it against the agent's identity — re-pin
# + setAgentURI after changing it (or after transferring the agent NFT when the
# payee is owner-derived), or the published card lies.
# Point X402_PAY_TO at the agent owner / treasury, NEVER the ALLOCATOR hot key
# (the agent refuses to start). Leave it blank with AGENT_ID set to derive the
# payee from the on-chain agent-NFT owner, ownerOf(AGENT_ID).
# x402 recipient: owner/treasury; blank = derive from ownerOf(AGENT_ID).
X402_PAY_TO=
# EIP-3009 token used to pay (e.g. USDC 0x09Bc4E0D...0dF9); enables the paid endpoint.
X402_ASSET=
# Price in token base units (10000 = 0.01 USDC, 6-dec).
X402_PRICE_BASE_UNITS=10000
# Human network label carried in requirements/receipts.
X402_NETWORK=mantle
# EIP-712 domain name of X402_ASSET.
X402_TOKEN_NAME=USD Coin
# EIP-712 domain version of X402_ASSET.
X402_TOKEN_VERSION=2
# How long a signed payment authorization stays valid (seconds).
X402_TIMEOUT_SECONDS=120
# Optional x402-gated feed the agent PAYS for; receipt pinned into decisions.
X402_PREMIUM_FEED_URL=
# REQUIRED when X402_PREMIUM_FEED_URL is set: reject feed prices above this
# (base units) before signing.
X402_MAX_PRICE_BASE_UNITS=
# true: settle /risk-score payments on-chain (needs ALLOCATOR wallet);
# false: verify signature, facilitator settles.
X402_SETTLE_ONCHAIN=false

# ── Agent service ─────────────────────────────────────────────────────────
AGENT_PORT=8080
AGENT_LOG_LEVEL=info
# Public URLs for the ERC-8004 agent card (`pnpm card:pin`): endpoints.api is
# required; the dashboard is optional. Falls back to VITE_AGENT_API_URL.
AGENT_API_URL=
AGENT_DASHBOARD_URL=

# ── Explorer verification (mantlescan) ────────────────────────────────────
MANTLESCAN_API_KEY=
