# Custos reverse proxy. Serves the SPA and proxies /api/* to the agent.
# Caddy auto-provisions Let's Encrypt TLS for the domain below.
trycustos.xyz {
	# Agent API
	handle_path /api/* {
		reverse_proxy agent:8080
	}

	# Static frontend (SPA fallback to index.html)
	handle {
		root * /srv
		try_files {path} /index.html
		file_server
	}

	encode gzip zstd
}
